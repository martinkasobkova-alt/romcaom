# Copy to .env and fill in. Never commit .env.
PORT=3000

# Long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change-this-to-a-long-random-secret

# Preferred: hash from `npm run hash-password -- "YourPassword"`
# Alternative (dev only): plain ADMIN_PASSWORD= (not for production)
ADMIN_PASSWORD_HASH=

# Optional dev fallback — leave empty in production
# ADMIN_PASSWORD=

# Původy prohlížeče, když API běží jinde než stránka (Vercel → Render) — víc domén = čárkou
# CORS_ORIGIN=https://romca-om.vercel.app,https://vase-domena.cz

# Dev: pro test z jiného portu než backend (1 = povolí běžné localhost/127.0.0.1:3000,5173,8000)
# CORS_ALLOW_LOCALHOST=0
