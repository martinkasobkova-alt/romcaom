# Copy to .env and fill in. Never commit .env.
PORT=3000

# Long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change-this-to-a-long-random-secret

# Preferred: hash from `npm run hash-password -- "YourPassword"`
# Alternative (dev only): plain ADMIN_PASSWORD= (not for production)
ADMIN_PASSWORD_HASH=

# Optional dev fallback — leave empty in production
# ADMIN_PASSWORD=

# Další původy mimo pevnou sadu v server.mjs (BUILTIN + všechny https://*.vercel.app) — oddělujte čárkou
# CORS_ORIGIN=https://moje-domena.cz,https://preview-jinde.onrender.com
